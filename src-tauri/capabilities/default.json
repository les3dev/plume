{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "Capability for the main window",
    "windows": ["main"],
    "permissions": [
        "core:default",
        "opener:default",
        "mic-recorder:default",
        "store:allow-load",
        "store:allow-get",
        "store:allow-set",
        "store:allow-save",
        "store:allow-delete",
        "dialog:default",
        "fs:default",
        {
            "identifier": "fs:allow-read-file",
            "allow": [{"path": "$APPDATA/**"}]
        },
        "fs:allow-read-file",
        "http:default",
        {
            "identifier": "http:allow-fetch",
            "allow": [{"url": "https://api.deepgram.com/**"}]
        },
        "positioner:default",
        "positioner:allow-move-window"
    ]
}
