{
    "useTabs": false,
    "tabWidth": 4,
    "singleQuote": true,
    "printWidth": 100,
    "trailingComma": "all",
    "bracketSpacing": false,
    "plugins": ["prettier-plugin-svelte", "prettier-plugin-tailwindcss"],
    "tailwindStylesheet": "./src/app.css",
    "overrides": [
        {
            "files": "*.svelte",
            "options": {
                "parser": "svelte",
                "tabWidth": 4
            }
        }
    ]
}
